def build_argument_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Compare previous/current transformation Excel outputs and generate an HTML QA report."
    )

    for config in DATASETS:
        argument_prefix = config.code.replace("_", "-")
        parser.add_argument(f"--{argument_prefix}-previous", type=Path)
        parser.add_argument(f"--{argument_prefix}-current", type=Path)
        parser.add_argument(f"--{argument_prefix}-previous-sheet")
        parser.add_argument(f"--{argument_prefix}-current-sheet")

    parser.add_argument("--output", type=Path, help="HTML report output path.")
    parser.add_argument("--no-open", action="store_true", help="Do not automatically open the report.")
    return parser


def get_argument_value(args: argparse.Namespace, config: DatasetConfig, suffix: str) -> Any:
    return getattr(args, f"{config.code}_{suffix}")


def resolve_inputs(args: argparse.Namespace, root: Optional[Any]) -> Tuple[Dict[str, Dict[str, Any]], Path]:
    resolved: Dict[str, Dict[str, Any]] = {}

    for config in DATASETS:
        previous_path = get_argument_value(args, config, "previous")
        current_path = get_argument_value(args, config, "current")

        if previous_path is None:
            if root is None:
                raise ValueError(
                    f"No previous file provided for {config.name}. Use --{config.code.replace('_', '-')}-previous."
                )
            previous_path = choose_excel_file(
                root,
                f"Select PREVIOUS {config.name} file",
                config.expected_filename,
            )

        if current_path is None:
            if root is None:
                raise ValueError(
                    f"No current file provided for {config.name}. Use --{config.code.replace('_', '-')}-current."
                )
            current_path = choose_excel_file(
                root,
                f"Select CURRENT {config.name} file",
                config.expected_filename,
            )

        previous_path = Path(previous_path).expanduser().resolve()
        current_path = Path(current_path).expanduser().resolve()

        if not previous_path.exists():
            raise FileNotFoundError(f"Previous {config.name} file does not exist: {previous_path}")
        if not current_path.exists():
            raise FileNotFoundError(f"Current {config.name} file does not exist: {current_path}")

        previous_sheet = choose_sheet(
            root,
            previous_path,
            f"previous {config.name}",
            get_argument_value(args, config, "previous_sheet"),
        )
        current_sheet = choose_sheet(
            root,
            current_path,
            f"current {config.name}",
            get_argument_value(args, config, "current_sheet"),
        )

        resolved[config.code] = {
            "previous_path": previous_path,
            "current_path": current_path,
            "previous_sheet": previous_sheet,
            "current_sheet": current_sheet,
        }

    output = args.output
    if output is None:
        if root is None:
            output = Path.cwd() / f"Transformation_QA_Report_{datetime.now():%Y%m%d_%H%M%S}.html"
        else:
            output = choose_output_file(root)

    output = Path(output).expanduser().resolve()
    if output.suffix.lower() not in {".html", ".htm"}:
        output = output.with_suffix(".html")
    output.parent.mkdir(parents=True, exist_ok=True)

    return resolved, output


def run_qa(resolved_inputs: Dict[str, Dict[str, Any]], output_path: Path) -> Path:
    comparisons: List[ComparisonResult] = []
    loaded_by_code: Dict[str, Dict[str, LoadedDataset]] = {}

    for config in DATASETS:
        selected = resolved_inputs[config.code]
        previous = load_dataset(
            config,
            "Previous",
            selected["previous_path"],
            selected["previous_sheet"],
        )
        current = load_dataset(
            config,
            "Current",
            selected["current_path"],
            selected["current_sheet"],
        )
        loaded_by_code[config.code] = {"previous": previous, "current": current}
        comparisons.append(compare_dataset(previous, current))

    previous_reconciliation = reconcile_demand(
        loaded_by_code["programme_demand"]["previous"],
        loaded_by_code["loadcap"]["previous"],
        "Previous",
    )
    current_reconciliation = reconcile_demand(
        loaded_by_code["programme_demand"]["current"],
        loaded_by_code["loadcap"]["current"],
        "Current",
    )

    report_html = build_report_html(
        comparisons,
        previous_reconciliation,
        current_reconciliation,
    )
    output_path.write_text(report_html, encoding="utf-8")
    return output_path


def show_error(root: Optional[Any], title: str, message: str) -> None:
    if root is not None and messagebox is not None:
        messagebox.showerror(title, message, parent=root)
    else:
        print(f"{title}: {message}", file=sys.stderr)


def show_success(root: Optional[Any], report_path: Path) -> None:
    message = f"QA report created successfully:\n\n{report_path}"
    if root is not None and messagebox is not None:
        messagebox.showinfo("QA report complete", message, parent=root)
    else:
        print(message)


def main() -> int:
    parser = build_argument_parser()
    args = parser.parse_args()

    needs_gui = any(
        get_argument_value(args, config, suffix) is None
        for config in DATASETS
        for suffix in ("previous", "current")
    ) or args.output is None

    root: Optional[Any] = None
    if needs_gui:
        if tk is None:
            parser.error(
                "Tkinter is unavailable, so file-picker mode cannot be used. "
                "Provide all file paths and --output on the command line."
            )
        root = create_hidden_root()

    try:
        resolved_inputs, output_path = resolve_inputs(args, root)
        report_path = run_qa(resolved_inputs, output_path)
        show_success(root, report_path)

        if AUTO_OPEN_REPORT and not args.no_open:
            webbrowser.open(report_path.as_uri())
        return 0

    except UserCancelledError as exc:
        print(str(exc))
        return 1
    except Exception as exc:
        detailed_message = f"{exc}\n\nTechnical details:\n{traceback.format_exc()}"
        show_error(root, "QA report failed", detailed_message)
        return 1
    finally:
        if root is not None:
            try:
                root.destroy()
            except Exception:
                pass


if __name__ == "__main__":
    raise SystemExit(main())
