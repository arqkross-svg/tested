# =============================================================================
# USER-ADJUSTABLE SETTINGS
# =============================================================================

# A 2x rule flags a value whose absolute magnitude becomes more than twice,
# or less than half, its previous magnitude. Changes to/from zero and sign
# changes are also flagged.
RATIO_THRESHOLD = 2.0

# Skills values are flagged when their absolute percentage change exceeds 25%.
SKILLS_PERCENT_THRESHOLD = 25.0

# Demand reconciliation passes when the two aggregated totals differ by no more
# than this number of FTE.
RECONCILIATION_TOLERANCE_FTE = 0.01

# Floating-point tolerance used to decide whether a numeric value changed.
NUMERIC_COMPARISON_TOLERANCE = 1e-9

# Limits each displayed HTML table to prevent unexpectedly enormous reports.
# Counts in the summary still use the full results.
MAX_HTML_ROWS_PER_TABLE = 5000

# Automatically open the finished report in the default browser.
AUTO_OPEN_REPORT = True

# Treat surrounding whitespace in key columns as insignificant.
STRIP_KEY_WHITESPACE = True


