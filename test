def safe_id(text: str) -> str:
    return "".join(character.lower() if character.isalnum() else "-" for character in text).strip("-")


def format_dataframe_for_html(df: pd.DataFrame) -> pd.DataFrame:
    formatted = df.copy()

    for column in formatted.columns:
        if pd.api.types.is_numeric_dtype(formatted[column]):
            if "Percentage" in column or column == "Percentage Change":
                formatted[column] = formatted[column].map(
                    lambda value: "" if pd.isna(value) else f"{value:,.2f}%"
                )
            elif "Ratio" in column or column == "Severity Score":
                formatted[column] = formatted[column].map(
                    lambda value: (
                        ""
                        if pd.isna(value)
                        else "∞"
                        if np.isinf(value)
                        else f"{value:,.2f}"
                    )
                )
            elif column in {"Source Excel Row", "Duplicate Row Count"}:
                formatted[column] = formatted[column].map(
                    lambda value: "" if pd.isna(value) else f"{int(value)}"
                )
            else:
                formatted[column] = formatted[column].map(
                    lambda value: "" if pd.isna(value) else f"{value:,.4f}".rstrip("0").rstrip(".")
                )
        else:
            formatted[column] = formatted[column].map(
                lambda value: "" if pd.isna(value) else str(value)
            )

    return formatted


def render_table(
    title: str,
    df: pd.DataFrame,
    description: str = "",
    open_by_default: bool = False,
) -> str:
    table_id = safe_id(title) + "-" + str(abs(hash(title)) % 100000)
    full_count = len(df)
    displayed = df.head(MAX_HTML_ROWS_PER_TABLE).copy()
    truncated = full_count > len(displayed)

    if df.empty:
        body = '<div class="empty-state">No issues found.</div>'
    else:
        formatted = format_dataframe_for_html(displayed)
        table_html = formatted.to_html(
            index=False,
            border=0,
            classes="qa-table",
            table_id=table_id,
            escape=True,
        )
        truncation_note = (
            f'<div class="warning-note">Showing the first {len(displayed):,} of {full_count:,} rows. '
            f'Increase <code>MAX_HTML_ROWS_PER_TABLE</code> in the script to display more.</div>'
            if truncated
            else ""
        )
        body = (
            f'<div class="table-toolbar">'
            f'<input class="table-search" type="search" placeholder="Filter this table..." '
            f'oninput="filterTable(\'{table_id}\', this.value)">'
            f'<span>{full_count:,} row(s)</span>'
            f'</div>{truncation_note}<div class="table-wrap">{table_html}</div>'
        )

    description_html = f'<p class="section-description">{html.escape(description)}</p>' if description else ""
    open_attribute = " open" if open_by_default else ""
    return (
        f'<details class="report-section"{open_attribute}>'
        f'<summary><span>{html.escape(title)}</span><span class="count-pill">{full_count:,}</span></summary>'
        f'<div class="section-content">{description_html}{body}</div>'
        f'</details>'
    )


def status_count(df: pd.DataFrame, status: str) -> int:
    if "Status" not in df.columns:
        return 0
    return int((df["Status"] == status).sum())


def build_summary_rows(
    comparisons: Sequence[ComparisonResult],
    previous_reconciliation: pd.DataFrame,
    current_reconciliation: pd.DataFrame,
) -> pd.DataFrame:
    rows: List[Dict[str, Any]] = []

    for result in comparisons:
        config = result.config
        rows.extend(
            [
                {
                    "Area": config.name,
                    "Check": "Missing detailed rows",
                    "Count": len(result.missing_rows),
                    "Result": "PASS" if result.missing_rows.empty else "ISSUES",
                },
                {
                    "Area": config.name,
                    "Check": f"Missing {config.entity_column} values",
                    "Count": len(result.missing_entities),
                    "Result": "PASS" if result.missing_entities.empty else "ISSUES",
                },
                {
                    "Area": config.name,
                    "Check": "Flagged value changes",
                    "Count": len(result.flagged_value_changes),
                    "Result": "PASS" if result.flagged_value_changes.empty else "ISSUES",
                },
                {
                    "Area": config.name,
                    "Check": "Previous duplicate rows",
                    "Count": len(result.previous.duplicates),
                    "Result": "PASS" if result.previous.duplicates.empty else "ISSUES",
                },
                {
                    "Area": config.name,
                    "Check": "Current duplicate rows",
                    "Count": len(result.current.duplicates),
                    "Result": "PASS" if result.current.duplicates.empty else "ISSUES",
                },
                {
                    "Area": config.name,
                    "Check": "Blank key rows",
                    "Count": len(result.previous.blank_key_issues) + len(result.current.blank_key_issues),
                    "Result": (
                        "PASS"
                        if result.previous.blank_key_issues.empty and result.current.blank_key_issues.empty
                        else "ISSUES"
                    ),
                },
                {
                    "Area": config.name,
                    "Check": "Invalid numeric values",
                    "Count": len(result.previous.numeric_issues) + len(result.current.numeric_issues),
                    "Result": (
                        "PASS"
                        if result.previous.numeric_issues.empty and result.current.numeric_issues.empty
                        else "ISSUES"
                    ),
                },
            ]
        )

    for snapshot, reconciliation in (
        ("Previous", previous_reconciliation),
        ("Current", current_reconciliation),
    ):
        issue_count = int((reconciliation["Status"] != "PASS").sum())
        rows.append(
            {
                "Area": f"Demand Reconciliation ({snapshot})",
                "Check": f"Year Quarter + HoC mismatches above {RECONCILIATION_TOLERANCE_FTE:g} FTE",
                "Count": issue_count,
                "Result": "PASS" if issue_count == 0 else "ISSUES",
            }
        )

    return pd.DataFrame(rows)


def metric_card(label: str, value: Any, variant: str = "neutral") -> str:
    return (
        f'<div class="metric-card {html.escape(variant)}">'
        f'<div class="metric-value">{html.escape(str(value))}</div>'
        f'<div class="metric-label">{html.escape(label)}</div>'
        f'</div>'
    )


