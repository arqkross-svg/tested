WITH RagValues AS
(
    SELECT
        t.Capability,
        t.ToolName,
        rag.RagValue
    FROM dbo.ToolHealth AS t

    CROSS APPLY
    (
        VALUES
            (t.RAG_Column_1),
            (t.RAG_Column_2),
            (t.RAG_Column_3),
            (t.RAG_Column_4),
            (t.RAG_Column_5),
            (t.RAG_Column_6),
            (t.RAG_Column_7),
            (t.RAG_Column_8),
            (t.RAG_Column_9),
            (t.RAG_Column_10),
            (t.RAG_Column_11)
    ) AS rag(RagValue)
),

CapabilityScores AS
(
    SELECT
        Capability,

        SUM(
            CASE
                WHEN UPPER(LTRIM(RTRIM(COALESCE(RagValue, ''))))
                    IN ('G', 'GREEN')
                    THEN 3

                WHEN UPPER(LTRIM(RTRIM(COALESCE(RagValue, ''))))
                    IN ('A', 'AMBER')
                    THEN 2

                WHEN UPPER(LTRIM(RTRIM(COALESCE(RagValue, ''))))
                    IN ('R', 'RED')
                    THEN 0

                /* Null or empty values count as Blank */
                ELSE 1
            END
        ) AS AchievedPoints,

        COUNT(*) * 3 AS MaximumPoints,

        SUM(
            CASE
                WHEN UPPER(LTRIM(RTRIM(COALESCE(RagValue, ''))))
                    IN ('G', 'GREEN')
                    THEN 1
                ELSE 0
            END
        ) AS GreenCount,

        SUM(
            CASE
                WHEN UPPER(LTRIM(RTRIM(COALESCE(RagValue, ''))))
                    IN ('A', 'AMBER')
                    THEN 1
                ELSE 0
            END
        ) AS AmberCount,

        SUM(
            CASE
                WHEN UPPER(LTRIM(RTRIM(COALESCE(RagValue, ''))))
                    IN ('R', 'RED')
                    THEN 1
                ELSE 0
            END
        ) AS RedCount,

        SUM(
            CASE
                WHEN NULLIF(LTRIM(RTRIM(RagValue)), '') IS NULL
                    THEN 1
                ELSE 0
            END
        ) AS BlankCount

    FROM RagValues

    GROUP BY
        Capability
)

SELECT
    Capability,
    GreenCount,
    AmberCount,
    RedCount,
    BlankCount,
    AchievedPoints,
    MaximumPoints,

    CAST(
        AchievedPoints * 100.0
        / NULLIF(MaximumPoints, 0)
        AS DECIMAL(5, 2)
    ) AS CapabilityHealthPercentage,

    CASE
        WHEN AchievedPoints * 100.0
             / NULLIF(MaximumPoints, 0) >= 75
            THEN 'Green'

        WHEN AchievedPoints * 100.0
             / NULLIF(MaximumPoints, 0) >= 50
            THEN 'Amber'

        ELSE 'Red'
    END AS CapabilityRAG

FROM CapabilityScores

ORDER BY
    Capability;
