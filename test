"""Compare two Demand.xlsx files and create an HTML QA report.

Install once:
    pip install pandas openpyxl
"""

from datetime import datetime
from html import escape
from pathlib import Path
import webbrowser

import pandas as pd
import tkinter as tk
from tkinter import filedialog, messagebox


# These columns identify one demand record.
KEY_COLUMNS = ["Year Quarter", "HoC", "Job Profile", "Programme"]
VALUE_COLUMN = "Demand (FTE)"
CHANGE_MULTIPLIER = 2


def choose_excel_file(title):
    """Open a window so the user can select an Excel file."""
    path = filedialog.askopenfilename(
        title=title,
        filetypes=[("Excel files", "*.xlsx *.xls")],
    )
    if not path:
        raise SystemExit("No Excel file was selected.")
    return Path(path)


def choose_report_location():
    """Open a window so the user can choose where to save the report."""
    path = filedialog.asksaveasfilename(
        title="Save the Demand QA report",
        initialfile=f"Demand_QA_{datetime.now():%Y%m%d_%H%M%S}.html",
        defaultextension=".html",
        filetypes=[("HTML report", "*.html")],
    )
    if not path:
        raise SystemExit("No report location was selected.")
    return Path(path)


def load_demand(file_path):
    """Read one Demand file and keep only the columns needed for QA."""
    data = pd.read_excel(file_path)
    required_columns = KEY_COLUMNS + [VALUE_COLUMN]

    missing_columns = [
        column for column in required_columns if column not in data.columns
    ]
    if missing_columns:
        raise ValueError(
            f"{file_path.name} is missing: {', '.join(missing_columns)}"
        )

    data = data[required_columns].copy()

    # Clean text identifiers so spaces do not create false changes.
    for column in KEY_COLUMNS:
        data[column] = data[column].fillna("").astype(str).str.strip()

    # Convert Demand to a number. Blank or invalid values become zero.
    data[VALUE_COLUMN] = pd.to_numeric(
        data[VALUE_COLUMN], errors="coerce"
    ).fillna(0)

    # Combine duplicate identifiers into one FTE total.
    return data.groupby(KEY_COLUMNS, as_index=False)[VALUE_COLUMN].sum()


def compare_demand(previous, current):
    """Compare previous and current demand and return four result tables."""
    old_fte = "Previous Demand (FTE)"
    new_fte = "Current Demand (FTE)"

    comparison = previous.merge(
        current,
        on=KEY_COLUMNS,
        how="outer",
        suffixes=(" Previous", " Current"),
        indicator=True,
    ).rename(
        columns={
            f"{VALUE_COLUMN} Previous": old_fte,
            f"{VALUE_COLUMN} Current": new_fte,
        }
    )

    # Rows that existed previously but no longer exist.
    missing_rows = comparison.loc[
        comparison["_merge"] == "left_only",
        KEY_COLUMNS + [old_fte],
    ].copy()

    # Rows that exist now but did not exist previously.
    new_rows = comparison.loc[
        comparison["_merge"] == "right_only",
        KEY_COLUMNS + [new_fte],
    ].copy()

    # Job Profiles that have disappeared from the whole file.
    missing_profiles = pd.DataFrame(
        {
            "Missing Job Profile": sorted(
                set(previous["Job Profile"]) - set(current["Job Profile"])
            )
        }
    )

    # Only compare FTE where the full identifier exists in both files.
    matched = comparison.loc[comparison["_merge"] == "both"].copy()
    old_value = matched[old_fte]
    new_value = matched[new_fte]

    large_change = (
        ((old_value == 0) & (new_value != 0))
        | ((old_value != 0) & (new_value > old_value * CHANGE_MULTIPLIER))
        | ((old_value != 0) & (new_value < old_value / CHANGE_MULTIPLIER))
    )

    large_changes = matched.loc[
        large_change,
        KEY_COLUMNS + [old_fte, new_fte],
    ].copy()

    large_changes["FTE Difference"] = (
        large_changes[new_fte] - large_changes[old_fte]
    )
    large_changes["Percentage Change"] = (
        large_changes["FTE Difference"]
        / large_changes[old_fte].replace(0, pd.NA)
        * 100
    )

    return missing_profiles, missing_rows, large_changes, new_rows


def html_table(data, pass_message):
    """Turn a result DataFrame into an HTML table."""
    if data.empty:
        return f'<p class="pass">✓ {pass_message}</p>'

    return data.to_html(
        index=False,
        border=0,
        float_format=lambda number: f"{number:,.2f}",
    )


def save_html_report(
    report_path,
    previous_path,
    current_path,
    previous,
    current,
    missing_profiles,
    missing_rows,
    large_changes,
    new_rows,
):
    """Create and save the HTML report."""
    summary = pd.DataFrame(
        {
            "Check": [
                "Previous rows",
                "Current rows",
                "Missing Job Profiles",
                "Missing rows",
                "Large FTE changes",
                "New rows",
            ],
            "Count": [
                len(previous),
                len(current),
                len(missing_profiles),
                len(missing_rows),
                len(large_changes),
                len(new_rows),
            ],
        }
    )

    sections = [
        (
            "Missing Job Profiles",
            "Profiles that existed previously but do not appear anywhere now.",
            missing_profiles,
            "No Job Profiles have disappeared.",
        ),
        (
            "Missing Rows",
            "Full Year Quarter, HoC, Job Profile and Programme combinations that disappeared.",
            missing_rows,
            "No previous rows are missing.",
        ),
        (
            "Large Demand Changes",
            "Matched rows that increased above 2x or fell below half.",
            large_changes,
            "No large Demand changes were found.",
        ),
        (
            "New Rows",
            "Rows that exist now but did not exist previously.",
            new_rows,
            "No new rows were found.",
        ),
    ]

    section_html = ""
    for title, description, data, pass_message in sections:
        section_html += f"""
<section>
<h2>{title}</h2>
<p>{description}</p>
{html_table(data, pass_message)}
</section>
"""

    report = f"""<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Demand QA Report</title>
<style>
body {{ font-family: Arial; margin: 30px; background: #f4f6f8; }}
section {{ background: white; padding: 18px; margin: 18px 0; overflow-x: auto; }}
table {{ border-collapse: collapse; width: 100%; }}
th, td {{ border: 1px solid #ddd; padding: 8px; text-align: left; }}
th {{ background: #e8f0fe; }}
.pass {{ color: green; font-weight: bold; }}
</style>
</head>
<body>
<h1>Demand QA Report</h1>
<p>Created {datetime.now():%d %B %Y at %H:%M}</p>
<section>
<b>Previous:</b> {escape(str(previous_path))}<br>
<b>Current:</b> {escape(str(current_path))}<br>
<b>Rule:</b> flag above {CHANGE_MULTIPLIER}x or below half
</section>
<section>
<h2>Summary</h2>
{summary.to_html(index=False, border=0)}
</section>
{section_html}
</body>
</html>"""

    report_path.write_text(report, encoding="utf-8")


def main():
    root = tk.Tk()
    root.withdraw()

    try:
        previous_path = choose_excel_file("Select the PREVIOUS Demand.xlsx")
        current_path = choose_excel_file("Select the CURRENT Demand.xlsx")
        report_path = choose_report_location()

        previous = load_demand(previous_path)
        current = load_demand(current_path)

        results = compare_demand(previous, current)
        missing_profiles, missing_rows, large_changes, new_rows = results

        save_html_report(
            report_path,
            previous_path,
            current_path,
            previous,
            current,
            missing_profiles,
            missing_rows,
            large_changes,
            new_rows,
        )

        messagebox.showinfo("Complete", f"Report saved to:\n{report_path}")
        webbrowser.open(report_path.resolve().as_uri())

    except Exception as error:
        messagebox.showerror("Demand QA error", str(error))
        raise
    finally:
        root.destroy()


if __name__ == "__main__":
    main()
