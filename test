def create_hidden_root() -> Optional[Any]:
    if tk is None:
        return None
    root = tk.Tk()
    root.withdraw()
    try:
        root.attributes("-topmost", True)
    except tk.TclError:
        pass
    return root


def choose_excel_file(root: Any, title: str, expected_filename: str) -> Path:
    if filedialog is None:
        raise RuntimeError("Tkinter file dialogs are unavailable in this Python installation.")

    selected = filedialog.askopenfilename(
        parent=root,
        title=title,
        filetypes=[
            (f"Expected file ({expected_filename})", expected_filename),
            ("Excel workbooks", "*.xlsx *.xlsm *.xls"),
            ("All files", "*.*"),
        ],
    )
    if not selected:
        raise UserCancelledError(f"No file selected for: {title}")
    return Path(selected)


def choose_output_file(root: Any) -> Path:
    if filedialog is None:
        raise RuntimeError("Tkinter file dialogs are unavailable in this Python installation.")

    default_name = f"Transformation_QA_Report_{datetime.now():%Y%m%d_%H%M%S}.html"
    selected = filedialog.asksaveasfilename(
        parent=root,
        title="Choose where to save the QA HTML report",
        defaultextension=".html",
        initialfile=default_name,
        filetypes=[("HTML report", "*.html"), ("All files", "*.*")],
    )
    if not selected:
        raise UserCancelledError("No report output location selected.")
    return Path(selected)


def choose_sheet(root: Any, workbook_path: Path, label: str, requested_sheet: Optional[str]) -> str:
    excel_file = pd.ExcelFile(workbook_path)
    sheets = excel_file.sheet_names

    if requested_sheet is not None:
        if requested_sheet not in sheets:
            raise ValueError(
                f"Sheet '{requested_sheet}' was not found in {workbook_path.name}. "
                f"Available sheets: {', '.join(sheets)}"
            )
        return requested_sheet

    if len(sheets) == 1:
        return sheets[0]

    if root is None or tk is None:
        raise ValueError(
            f"{workbook_path.name} contains multiple sheets. Specify one using the appropriate "
            f"command-line --*-sheet argument. Available sheets: {', '.join(sheets)}"
        )

    dialog = tk.Toplevel(root)
    dialog.title(f"Select sheet: {label}")
    dialog.resizable(False, False)
    try:
        dialog.attributes("-topmost", True)
    except tk.TclError:
        pass

    selection = tk.StringVar(value=sheets[0])
    cancelled = {"value": True}

    tk.Label(
        dialog,
        text=f"{workbook_path.name} contains multiple worksheets.\nSelect the worksheet for {label}:",
        justify="left",
        padx=16,
        pady=12,
    ).pack(anchor="w")

    option_menu = tk.OptionMenu(dialog, selection, *sheets)
    option_menu.config(width=max(25, min(60, max(len(s) for s in sheets) + 4)))
    option_menu.pack(padx=16, pady=(0, 12), fill="x")

    button_frame = tk.Frame(dialog)
    button_frame.pack(padx=16, pady=(0, 16), fill="x")

    def accept() -> None:
        cancelled["value"] = False
        dialog.destroy()

    def cancel() -> None:
        dialog.destroy()

    tk.Button(button_frame, text="Use this sheet", command=accept, width=16).pack(side="left")
    tk.Button(button_frame, text="Cancel", command=cancel, width=10).pack(side="right")

    dialog.protocol("WM_DELETE_WINDOW", cancel)
    dialog.grab_set()
    dialog.wait_visibility()
    dialog.focus_force()
    root.wait_window(dialog)

    if cancelled["value"]:
        raise UserCancelledError(f"No worksheet selected for {label}.")
    return selection.get()


class UserCancelledError(Exception):
    """Raised when a user cancels a file or sheet selection dialog."""


# =============================================================================
# DATA LOADING AND VALIDATION
# =============================================================================


def normalise_headers(columns: Sequence[Any]) -> List[str]:
    return [str(column).strip() for column in columns]


def clean_key_value(value: Any) -> Any:
    if pd.isna(value):
        return pd.NA
    if isinstance(value, str):
        cleaned = value.strip() if STRIP_KEY_WHITESPACE else value
        return pd.NA if cleaned == "" else cleaned
    return value


def require_columns(df: pd.DataFrame, config: DatasetConfig, path: Path, sheet_name: str) -> None:
    required = list(config.keys) + list(config.values.keys())
    missing = [column for column in required if column not in df.columns]
    if missing:
        raise ValueError(
            f"{config.name}: required columns are missing from '{path.name}' / sheet '{sheet_name}':\n"
            f"  - " + "\n  - ".join(missing) + "\n\n"
            f"Columns found:\n  - " + "\n  - ".join(map(str, df.columns))
        )


def aggregate_prepared_data(df: pd.DataFrame, config: DatasetConfig) -> pd.DataFrame:
    aggregation_functions: Dict[str, Callable[[pd.Series], float]] = {}

    for column, rule in config.values.items():
        if rule.aggregation == "sum":
            aggregation_functions[column] = lambda series: series.sum(min_count=1)
        elif rule.aggregation == "mean":
            aggregation_functions[column] = lambda series: series.mean()
        else:
            raise ValueError(f"Unsupported aggregation '{rule.aggregation}' for {config.name}.{column}")

    aggregated = (
        df.groupby(list(config.keys), dropna=False, sort=False)
        .agg(aggregation_functions)
        .reset_index()
    )
    return aggregated


def load_dataset(
    config: DatasetConfig,
    snapshot: str,
    path: Path,
    sheet_name: str,
) -> LoadedDataset:
    try:
        df = pd.read_excel(path, sheet_name=sheet_name)
    except Exception as exc:
        raise RuntimeError(
            f"Could not read {config.name} {snapshot.lower()} file:\n{path}\nSheet: {sheet_name}\n\n{exc}"
        ) from exc

    df.columns = normalise_headers(df.columns)
    require_columns(df, config, path, sheet_name)

    raw_row_count = len(df)
    relevant_columns = list(config.keys) + list(config.values.keys())
    prepared = df.loc[:, relevant_columns].copy()
    prepared.insert(0, "Source Excel Row", np.arange(2, len(prepared) + 2))

    for key in config.keys:
        prepared[key] = prepared[key].map(clean_key_value)

    blank_mask = prepared[list(config.keys)].isna().any(axis=1)
    blank_key_issues = prepared.loc[
        blank_mask,
        ["Source Excel Row", *config.keys, *config.values.keys()],
    ].copy()
    if not blank_key_issues.empty:
        blank_columns = []
        for _, row in blank_key_issues.iterrows():
            missing_for_row = [key for key in config.keys if pd.isna(row[key])]
            blank_columns.append(", ".join(missing_for_row))
        blank_key_issues.insert(1, "Blank Key Columns", blank_columns)
        blank_key_issues.insert(0, "Snapshot", snapshot)

    numeric_issue_frames: List[pd.DataFrame] = []
    for value_column in config.values:
        original = prepared[value_column].copy()
        converted = pd.to_numeric(original, errors="coerce")
        invalid_mask = original.notna() & converted.isna()

        if invalid_mask.any():
            issues = prepared.loc[invalid_mask, ["Source Excel Row", *config.keys]].copy()
            issues.insert(0, "Snapshot", snapshot)
            issues["Value Column"] = value_column
            issues["Invalid Value"] = original.loc[invalid_mask].astype(str).values
            numeric_issue_frames.append(issues)

        prepared[value_column] = converted

    numeric_issues = (
        pd.concat(numeric_issue_frames, ignore_index=True)
        if numeric_issue_frames
        else pd.DataFrame(columns=["Snapshot", "Source Excel Row", *config.keys, "Value Column", "Invalid Value"])
    )

    duplicate_mask = prepared.duplicated(subset=list(config.keys), keep=False)
    duplicate_rows = prepared.loc[
        duplicate_mask,
        ["Source Excel Row", *config.keys, *config.values.keys()],
    ].copy()

    if duplicate_rows.empty:
        duplicates = pd.DataFrame(columns=["Snapshot", *config.keys, "Duplicate Row Count"])
    else:
        duplicate_counts = (
            duplicate_rows.groupby(list(config.keys), dropna=False)
            .size()
            .rename("Duplicate Row Count")
            .reset_index()
        )
        duplicates = duplicate_rows.merge(duplicate_counts, on=list(config.keys), how="left")
        duplicates.insert(0, "Snapshot", snapshot)
        duplicates = duplicates.sort_values(
            ["Duplicate Row Count", *config.keys],
            ascending=[False] + [True] * len(config.keys),
            kind="stable",
        ).reset_index(drop=True)

    # Keep rows with blank keys in QA issue tables, but exclude them from key-based
    # comparisons because they cannot form a reliable identifier.
    comparison_ready = prepared.loc[~blank_mask, relevant_columns].copy()
    aggregated = aggregate_prepared_data(comparison_ready, config)

    return LoadedDataset(
        config=config,
        snapshot=snapshot,
        path=path,
        sheet_name=sheet_name,
        raw_row_count=raw_row_count,
        prepared=prepared,
        aggregated=aggregated,
        duplicates=duplicates,
        blank_key_issues=blank_key_issues,
        numeric_issues=numeric_issues,
    )


# =============================================================================
# COMPARISON LOGIC
# =============================================================================


def numeric_values_equal(previous: pd.Series, current: pd.Series) -> pd.Series:
    both_missing = previous.isna() & current.isna()
    one_missing = previous.isna() ^ current.isna()
    numeric_close = pd.Series(False, index=previous.index)

    valid = ~(previous.isna() | current.isna())
    if valid.any():
        numeric_close.loc[valid] = np.isclose(
            previous.loc[valid].astype(float),
            current.loc[valid].astype(float),
            rtol=0.0,
            atol=NUMERIC_COMPARISON_TOLERANCE,
            equal_nan=True,
        )
    return (both_missing | numeric_close) & ~one_missing


def calculate_change_metrics(previous: Any, current: Any) -> Dict[str, Any]:
    previous_missing = pd.isna(previous)
    current_missing = pd.isna(current)

    if previous_missing or current_missing:
        return {
            "Absolute Change": np.nan,
            "Percentage Change": np.nan,
            "Magnitude Ratio": np.nan,
        }

    previous_float = float(previous)
    current_float = float(current)
    absolute_change = current_float - previous_float

    if math.isclose(previous_float, 0.0, abs_tol=NUMERIC_COMPARISON_TOLERANCE):
        percentage_change = np.nan
        magnitude_ratio = np.inf if not math.isclose(current_float, 0.0, abs_tol=NUMERIC_COMPARISON_TOLERANCE) else 1.0
    else:
        percentage_change = (absolute_change / abs(previous_float)) * 100.0
        magnitude_ratio = abs(current_float) / abs(previous_float)

    return {
        "Absolute Change": absolute_change,
        "Percentage Change": percentage_change,
        "Magnitude Ratio": magnitude_ratio,
    }


def evaluate_rule(previous: Any, current: Any, rule: ValueRule) -> Tuple[bool, str, float]:
    previous_missing = pd.isna(previous)
    current_missing = pd.isna(current)

    if previous_missing and current_missing:
        return False, "Both values blank", 0.0
    if previous_missing and not current_missing:
        return True, "Previous value blank", float("inf")
    if current_missing and not previous_missing:
        return True, "Current value blank", float("inf")

    previous_float = float(previous)
    current_float = float(current)
    previous_zero = math.isclose(previous_float, 0.0, abs_tol=NUMERIC_COMPARISON_TOLERANCE)
    current_zero = math.isclose(current_float, 0.0, abs_tol=NUMERIC_COMPARISON_TOLERANCE)

    if previous_zero and current_zero:
        return False, "No change", 0.0
    if previous_zero and not current_zero:
        return True, "Changed from zero", float("inf")
    if not previous_zero and current_zero:
        return True, "Changed to zero", float("inf")

    sign_changed = np.sign(previous_float) != np.sign(current_float)

    if rule.rule_type == "ratio":
        ratio = abs(current_float) / abs(previous_float)
        upper_flag = ratio > rule.threshold
        lower_flag = ratio < (1.0 / rule.threshold)

        if sign_changed:
            return True, "Sign changed", max(ratio, 1.0 / ratio if ratio else float("inf"))
        if upper_flag:
            return True, f"Magnitude increased beyond {rule.threshold:g}x", ratio
        if lower_flag:
            inverse_ratio = 1.0 / ratio if ratio else float("inf")
            return True, f"Magnitude decreased beyond {rule.threshold:g}x", inverse_ratio
        return False, "Within ratio threshold", max(ratio, 1.0 / ratio if ratio else float("inf"))

    if rule.rule_type == "percent":
        percent_change = ((current_float - previous_float) / abs(previous_float)) * 100.0
        severity = abs(percent_change) / rule.threshold if rule.threshold else abs(percent_change)

        if sign_changed:
            return True, "Sign changed", severity
        if abs(percent_change) > rule.threshold:
            return True, f"Absolute percentage change above {rule.threshold:g}%", severity
        return False, "Within percentage threshold", severity

    raise ValueError(f"Unsupported rule type: {rule.rule_type}")


def compare_dataset(previous: LoadedDataset, current: LoadedDataset) -> ComparisonResult:
    config = previous.config
    keys = list(config.keys)
    value_columns = list(config.values.keys())

    merged = previous.aggregated.merge(
        current.aggregated,
        on=keys,
        how="outer",
        suffixes=(" Previous", " Current"),
        indicator=True,
    )

    missing_rows = merged.loc[merged["_merge"] == "left_only", keys].copy()
    for column in value_columns:
        missing_rows[f"Previous {column}"] = merged.loc[merged["_merge"] == "left_only", f"{column} Previous"].values
    if not missing_rows.empty:
        missing_rows.insert(0, "Status", "MISSING FROM CURRENT")

    new_rows = merged.loc[merged["_merge"] == "right_only", keys].copy()
    for column in value_columns:
        new_rows[f"Current {column}"] = merged.loc[merged["_merge"] == "right_only", f"{column} Current"].values
    if not new_rows.empty:
        new_rows.insert(0, "Status", "NEW IN CURRENT")

    previous_entities = set(previous.aggregated[config.entity_column].dropna().astype(str))
    current_entities = set(current.aggregated[config.entity_column].dropna().astype(str))

    missing_entities = pd.DataFrame(
        {config.entity_column: sorted(previous_entities - current_entities)}
    )
    if not missing_entities.empty:
        missing_entities.insert(0, "Status", "MISSING FROM CURRENT")

    new_entities = pd.DataFrame(
        {config.entity_column: sorted(current_entities - previous_entities)}
    )
    if not new_entities.empty:
        new_entities.insert(0, "Status", "NEW IN CURRENT")

    matched = merged.loc[merged["_merge"] == "both"].copy()
    change_frames: List[pd.DataFrame] = []

    for value_column, rule in config.values.items():
        previous_column = f"{value_column} Previous"
        current_column = f"{value_column} Current"
        changed_mask = ~numeric_values_equal(matched[previous_column], matched[current_column])
        changed = matched.loc[changed_mask, keys + [previous_column, current_column]].copy()

        if changed.empty:
            continue

        records: List[Dict[str, Any]] = []
        for _, row in changed.iterrows():
            previous_value = row[previous_column]
            current_value = row[current_column]
            metrics = calculate_change_metrics(previous_value, current_value)
            is_flagged, reason, severity = evaluate_rule(previous_value, current_value, rule)

            record = {key: row[key] for key in keys}
            record.update(
                {
                    "Value Column": value_column,
                    "Previous Value": previous_value,
                    "Current Value": current_value,
                    **metrics,
                    "Rule": (
                        f"More than {rule.threshold:g}x / less than {1 / rule.threshold:g}x"
                        if rule.rule_type == "ratio"
                        else f"Absolute change above {rule.threshold:g}%"
                    ),
                    "Flagged": "YES" if is_flagged else "NO",
                    "Flag Reason": reason,
                    "Severity Score": severity,
                }
            )
            records.append(record)

        change_frames.append(pd.DataFrame.from_records(records))

    if change_frames:
        all_value_changes = pd.concat(change_frames, ignore_index=True)
        flagged_order = pd.Categorical(
            all_value_changes["Flagged"],
            categories=["YES", "NO"],
            ordered=True,
        )
        all_value_changes = (
            all_value_changes.assign(_flagged_order=flagged_order)
            .sort_values(
                ["_flagged_order", "Severity Score", "Value Column"],
                ascending=[True, False, True],
                kind="stable",
            )
            .drop(columns="_flagged_order")
            .reset_index(drop=True)
        )
    else:
        all_value_changes = pd.DataFrame(
            columns=[
                *keys,
                "Value Column",
                "Previous Value",
                "Current Value",
                "Absolute Change",
                "Percentage Change",
                "Magnitude Ratio",
                "Rule",
                "Flagged",
                "Flag Reason",
                "Severity Score",
            ]
        )

    flagged_value_changes = all_value_changes.loc[
        all_value_changes["Flagged"] == "YES"
    ].copy()
    if not flagged_value_changes.empty:
        flagged_value_changes.insert(0, "Status", "FLAGGED CHANGE")

    return ComparisonResult(
        config=config,
        previous=previous,
        current=current,
        missing_rows=missing_rows.reset_index(drop=True),
        new_rows=new_rows.reset_index(drop=True),
        missing_entities=missing_entities.reset_index(drop=True),
        new_entities=new_entities.reset_index(drop=True),
        all_value_changes=all_value_changes,
        flagged_value_changes=flagged_value_changes.reset_index(drop=True),
        matched_row_count=len(matched),
    )


# =============================================================================
# CROSS-FILE RECONCILIATION
# =============================================================================


def reconcile_demand(
    demand: LoadedDataset,
    loadcap: LoadedDataset,
    snapshot: str,
) -> pd.DataFrame:
    demand_grouped = (
        demand.prepared.dropna(subset=list(RECONCILIATION_KEYS))
        .groupby(list(RECONCILIATION_KEYS), dropna=False)["Demand (FTE)"]
        .sum(min_count=1)
        .rename("Programme Demand Total (FTE)")
        .reset_index()
    )

    loadcap_grouped = (
        loadcap.prepared.dropna(subset=list(RECONCILIATION_KEYS))
        .groupby(list(RECONCILIATION_KEYS), dropna=False)["JP Demand (FTE)"]
        .sum(min_count=1)
        .rename("LoadCap JP Demand Total (FTE)")
        .reset_index()
    )

    reconciled = demand_grouped.merge(
        loadcap_grouped,
        on=list(RECONCILIATION_KEYS),
        how="outer",
        indicator=True,
    )
    reconciled.insert(0, "Snapshot", snapshot)

    reconciled["Difference (Programme - LoadCap)"] = (
        reconciled["Programme Demand Total (FTE)"]
        - reconciled["LoadCap JP Demand Total (FTE)"]
    )
    reconciled["Absolute Difference (FTE)"] = reconciled[
        "Difference (Programme - LoadCap)"
    ].abs()

    programme_total = reconciled["Programme Demand Total (FTE)"]
    reconciled["Percentage Difference vs Programme Demand"] = np.where(
        programme_total.notna() & ~np.isclose(programme_total.fillna(0), 0.0),
        (reconciled["Difference (Programme - LoadCap)"] / programme_total.abs()) * 100.0,
        np.nan,
    )

    status = np.select(
        [
            reconciled["_merge"] == "left_only",
            reconciled["_merge"] == "right_only",
            reconciled["Absolute Difference (FTE)"] > RECONCILIATION_TOLERANCE_FTE,
        ],
        [
            "MISSING FROM LOADCAP",
            "MISSING FROM PROGRAMME DEMAND",
            "MISMATCH",
        ],
        default="PASS",
    )
    reconciled.insert(1, "Status", status)
    reconciled = reconciled.drop(columns="_merge")

    status_order = pd.Categorical(
        reconciled["Status"],
        categories=[
            "MISSING FROM LOADCAP",
            "MISSING FROM PROGRAMME DEMAND",
            "MISMATCH",
            "PASS",
        ],
        ordered=True,
    )
    reconciled = (
        reconciled.assign(_status_order=status_order)
        .sort_values(
            ["_status_order", "Absolute Difference (FTE)", *RECONCILIATION_KEYS],
            ascending=[True, False, True, True],
            kind="stable",
        )
        .drop(columns="_status_order")
        .reset_index(drop=True)
    )
    return reconciled


