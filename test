@dataclass(frozen=True)
class ValueRule:
    rule_type: str  # "ratio" or "percent"
    threshold: float
    aggregation: str  # "sum" or "mean"


@dataclass(frozen=True)
class DatasetConfig:
    code: str
    name: str
    expected_filename: str
    keys: Tuple[str, ...]
    entity_column: str
    values: Dict[str, ValueRule]


